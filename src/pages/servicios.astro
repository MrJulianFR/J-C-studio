---
import CTASection from '../components/CTASection.astro';
import Features from '../components/Features.astro';
import Layout from '../layouts/Layout.astro';
import { WHATSAPP_LINK } from '../data/site';

const serviceItems = [
  {
    title: 'Responde en segundos y no pierdes clientes',
    description: 'Atencion inmediata para evitar que el prospecto se vaya con otra clinica.'
  },
  {
    title: 'Agenda citas automaticamente',
    description: 'Menos friccion para el paciente y mas ocupacion real de agenda.'
  },
  {
    title: 'Hace seguimiento por ti',
    description: 'Recupera prospectos indecisos con mensajes que empujan al cierre.'
  },
  {
    title: 'Convierte mas conversaciones en ventas',
    description: 'Un flujo comercial pensado para clinicas que quieren crecer ingresos.'
  }
];
---

<Layout
  title="Servicios J&C Studio | Convierte mensajes en citas automaticamente"
  description="Automatizacion WhatsApp clinicas para convertir mensajes en citas automaticamente, con seguimiento y mas ventas en Medellin."
  path="/servicios"
>
  <section class="mx-auto w-full max-w-6xl px-4 py-14 md:px-8 md:py-18" data-reveal>
    <p class="inline-flex rounded-full border border-sky-200 bg-sky-50 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-sky-700">Servicios</p>
    <h1 class="mt-4 text-balance text-4xl font-black leading-tight text-slate-900 md:text-5xl">Convierte mensajes de WhatsApp en citas automaticamente</h1>
    <p class="mt-5 max-w-3xl text-lg text-slate-600">Implementamos un sistema que responde en segundos, hace seguimiento y convierte prospectos en pacientes sin que pierdas oportunidades.</p>
    <a href={WHATSAPP_LINK} target="_blank" rel="noopener noreferrer" class="btn-primary mt-6" data-cta-whatsapp="services_hero">Ver demo en WhatsApp</a>
  </section>

  <Features heading="Lo que ganas con J&C Studio" items={serviceItems} />

  <section class="mx-auto w-full max-w-6xl px-4 py-12 md:px-8 md:py-16">
    <h2 class="text-3xl font-black text-slate-900 md:text-4xl" data-reveal>Impacto esperado desde el primer mes</h2>
    <ul class="mt-6 grid gap-3 text-sm text-slate-700 md:grid-cols-2">
      <li class="rounded-xl border border-emerald-200 bg-emerald-50 p-4" data-reveal>Respuesta en menos de 1 minuto.</li>
      <li class="rounded-xl border border-emerald-200 bg-emerald-50 p-4" data-reveal style="transition-delay:70ms">Mas citas agendadas con pacientes calificados.</li>
      <li class="rounded-xl border border-emerald-200 bg-emerald-50 p-4" data-reveal style="transition-delay:140ms">Menos chats perdidos sin seguimiento.</li>
      <li class="rounded-xl border border-emerald-200 bg-emerald-50 p-4" data-reveal style="transition-delay:210ms">Mas conversion y mejor retorno comercial.</li>
    </ul>
  </section>

  <CTASection
    title="No pagues mas leads para seguir perdiendolos por WhatsApp"
    description="Activa un sistema comercial que responde, califica y agenda por ti para convertir mas conversaciones en ingresos."
    primaryButtonText="Probar ahora en WhatsApp"
    primaryButtonHref={WHATSAPP_LINK}
  />
</Layout>
