---
import CTASection from '../components/CTASection.astro';
import Features from '../components/Features.astro';
import Hero from '../components/Hero.astro';
import Testimonials from '../components/Testimonials.astro';
import Layout from '../layouts/Layout.astro';
import { WHATSAPP_LINK } from '../data/site';

const benefits = [
  {
    title: 'Responde en segundos y no pierdes clientes',
    description: 'Cada nuevo mensaje recibe respuesta inmediata, incluso fuera de horario.'
  },
  {
    title: 'Agenda citas automaticamente',
    description: 'El sistema propone horarios y lleva al prospecto directo a una cita confirmada.'
  },
  {
    title: 'Hace seguimiento por ti',
    description: 'Recupera prospectos frios sin que tu equipo persiga manualmente cada chat.'
  },
  {
    title: 'Convierte mas conversaciones en ventas',
    description: 'Menos preguntas sueltas y mas pacientes listos para tratamiento.'
  }
];

const testimonials = [
  {
    quote: 'Pasamos de responder en 2 horas a responder en segundos. Subimos 34% las citas en 6 semanas.',
    name: 'Laura Giraldo',
    clinic: 'Directora, Clinica Armonia Facial'
  },
  {
    quote: 'Ahora tenemos citas todos los dias sin estar pegados al WhatsApp.',
    name: 'Camilo Restrepo',
    clinic: 'Gerente, Medicina Estetica Nova Skin'
  },
  {
    quote: 'El seguimiento automatico nos ayudo a llenar agenda de depilacion laser y tratamientos corporales.',
    name: 'Maria Jose Salazar',
    clinic: 'Coordinadora, Estetica Contorno Medellin'
  }
];

const faqs = [
  {
    q: 'Cuanto tarda la implementacion?',
    a: 'Normalmente entre 7 y 12 dias, dependiendo de la complejidad de tus tratamientos y proceso comercial.'
  },
  {
    q: 'Sirve para cualquier clinica estetica?',
    a: 'Si. Adaptamos el flujo para clinicas faciales, corporales, depilacion laser y medicina estetica avanzada.'
  },
  {
    q: 'Necesito cambiar mi numero de WhatsApp?',
    a: 'No necesariamente. Revisamos tu operacion actual y priorizamos una implementacion sin friccion para tu equipo.'
  },
  {
    q: 'Como medimos resultados?',
    a: 'Seguimos indicadores de tiempo de respuesta, citas agendadas, asistencia y recuperacion de prospectos.'
  }
];
---

<Layout
  title="J&C Studio | Convierte mensajes de WhatsApp en citas automaticamente"
  description="Automatizacion WhatsApp clinicas para convertir mensajes en citas automaticamente. Respuesta rapida, seguimiento y mas ventas para clinicas esteticas en Medellin."
  path="/"
>
  <Hero
    title="Convierte mensajes de WhatsApp en citas automaticamente"
    subtitle="Implementamos un sistema que responde en segundos, hace seguimiento y convierte prospectos en pacientes sin que pierdas oportunidades."
    ctaText="Probar ahora en WhatsApp"
    ctaHref={WHATSAPP_LINK}
  />

  <section class="mx-auto w-full max-w-6xl px-4 py-6 md:px-8 md:py-8">
    <div class="grid gap-4 md:grid-cols-2">
      <article class="rounded-2xl border border-rose-200 bg-rose-50 p-6" data-reveal>
        <p class="text-xs font-bold uppercase tracking-[0.14em] text-rose-700">Dolor real</p>
        <h2 class="mt-2 text-2xl font-black text-rose-900">La mayoria de clinicas pierde clientes por responder tarde o no hacer seguimiento</h2>
        <p class="mt-3 text-sm leading-relaxed text-rose-800">Si cada cliente vale <span class="font-extrabold">$200.000</span> y pierdes 10 al mes, estas dejando <span class="font-extrabold">$2.000.000</span> sobre la mesa.</p>
      </article>
      <article class="rounded-2xl border border-emerald-200 bg-emerald-50 p-6" data-reveal style="transition-delay:90ms">
        <p class="text-xs font-bold uppercase tracking-[0.14em] text-emerald-700">Solucion</p>
        <h2 class="mt-2 text-2xl font-black text-emerald-900">No es solo un chatbot</h2>
        <p class="mt-3 text-sm leading-relaxed text-emerald-800">Es un sistema que hace seguimiento hasta convertir cada conversacion en una cita.</p>
        <a href={WHATSAPP_LINK} target="_blank" rel="noopener noreferrer" class="btn-primary mt-5" data-cta-whatsapp="pain_section_cta">Ver demo en WhatsApp</a>
      </article>
    </div>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 pb-2 md:px-8">
    <div class="grid gap-3 rounded-2xl border border-slate-200 bg-white p-4 text-center sm:grid-cols-2 md:grid-cols-4 md:p-6" data-reveal>
      <p class="text-sm font-semibold text-slate-700">Clinicas faciales</p>
      <p class="text-sm font-semibold text-slate-700">Depilacion laser</p>
      <p class="text-sm font-semibold text-slate-700">Tratamientos corporales</p>
      <p class="text-sm font-semibold text-slate-700">Medicina estetica</p>
    </div>
  </section>

  <Features heading="Beneficios directos para vender mas por WhatsApp" items={benefits} />

  <section class="mx-auto w-full max-w-6xl px-4 py-14 md:px-8 md:py-18">
    <h2 class="text-balance text-3xl font-black text-slate-900 md:text-4xl" data-reveal>Como funciona (ultra simple)</h2>
    <div class="mt-8 grid gap-4 md:grid-cols-3">
      <article class="surface-card p-6" data-reveal>
        <p class="text-xs font-bold uppercase tracking-wide text-slate-500">1</p>
        <h3 class="mt-2 text-lg font-bold text-slate-900">El cliente escribe</h3>
        <p class="mt-2 text-sm text-slate-600">Llega el mensaje por WhatsApp desde Instagram, pauta o referido.</p>
      </article>
      <article class="surface-card p-6" data-reveal style="transition-delay:90ms">
        <p class="text-xs font-bold uppercase tracking-wide text-slate-500">2</p>
        <h3 class="mt-2 text-lg font-bold text-slate-900">El sistema responde y califica</h3>
        <p class="mt-2 text-sm text-slate-600">Pregunta, segmenta y filtra para identificar prospectos con mas intencion de compra.</p>
      </article>
      <article class="surface-card p-6" data-reveal style="transition-delay:180ms">
        <p class="text-xs font-bold uppercase tracking-wide text-slate-500">3</p>
        <h3 class="mt-2 text-lg font-bold text-slate-900">Se agenda la cita automaticamente</h3>
        <p class="mt-2 text-sm text-slate-600">El prospecto pasa a cita confirmada y seguimiento sin depender de respuesta manual.</p>
      </article>
    </div>
    <div class="mt-8 flex justify-center" data-reveal>
      <a href={WHATSAPP_LINK} target="_blank" rel="noopener noreferrer" class="btn-primary" data-cta-whatsapp="home_mid_cta">Quiero este sistema en mi clinica</a>
    </div>
  </section>

  <Testimonials items={testimonials} />

  <section class="mx-auto w-full max-w-6xl px-4 py-14 md:px-8 md:py-18">
    <h2 class="text-balance text-3xl font-black text-slate-900 md:text-4xl" data-reveal>Resultados de referencia en clinicas con alto volumen</h2>
    <div class="mt-8 grid gap-4 md:grid-cols-3">
      <article class="rounded-2xl border border-emerald-200 bg-emerald-50 p-6" data-reveal>
        <p class="text-xs font-bold uppercase tracking-wide text-emerald-700">Caso 1 · Clinica facial</p>
        <p class="mt-3 text-3xl font-black text-emerald-900">+34%</p>
        <p class="mt-2 text-sm text-emerald-800">Crecimiento de citas agendadas en 6 semanas.</p>
      </article>
      <article class="rounded-2xl border border-emerald-200 bg-emerald-50 p-6" data-reveal style="transition-delay:90ms">
        <p class="text-xs font-bold uppercase tracking-wide text-emerald-700">Caso 2 · Depilacion laser</p>
        <p class="mt-3 text-3xl font-black text-emerald-900">-61%</p>
        <p class="mt-2 text-sm text-emerald-800">Reduccion de chats perdidos sin seguimiento.</p>
      </article>
      <article class="rounded-2xl border border-emerald-200 bg-emerald-50 p-6" data-reveal style="transition-delay:180ms">
        <p class="text-xs font-bold uppercase tracking-wide text-emerald-700">Caso 3 · Clinica corporal</p>
        <p class="mt-3 text-3xl font-black text-emerald-900">&lt; 1 min</p>
        <p class="mt-2 text-sm text-emerald-800">Tiempo de primera respuesta en WhatsApp.</p>
      </article>
    </div>
    <div class="mt-7 flex justify-center" data-reveal>
      <a href={WHATSAPP_LINK} target="_blank" rel="noopener noreferrer" class="btn-primary" data-cta-whatsapp="home_results_cta">Ver demo en WhatsApp</a>
    </div>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 py-14 md:px-8 md:py-18">
    <h2 class="text-balance text-3xl font-black text-slate-900 md:text-4xl" data-reveal>Preguntas frecuentes sobre automatizacion WhatsApp clinicas</h2>
    <div class="mt-8 space-y-3">
      {
        faqs.map((faq, index) => (
          <details class="surface-card p-5" data-reveal style={`transition-delay:${index * 70}ms`}>
            <summary class="cursor-pointer list-none text-base font-bold text-slate-900">{faq.q}</summary>
            <p class="mt-3 text-sm leading-relaxed text-slate-600">{faq.a}</p>
          </details>
        ))
      }
    </div>
  </section>

  <CTASection
    title="Si hoy respondes tarde, hoy mismo estas perdiendo dinero"
    description="Agenda una asesoria por WhatsApp y te mostramos como convertir mas conversaciones en citas y mas citas en ingresos para tu clinica."
    buttonText="Ver demo en WhatsApp"
    buttonHref={WHATSAPP_LINK}
  />
</Layout>
