---
interface Props {
  title: string;
  description: string;
  primaryButtonText?: string;
  primaryButtonHref: string;
  secondaryButtonText?: string;
  secondaryButtonHref?: string;
}

const {
  title,
  description,
  primaryButtonText = 'Agendar auditoria gratuita',
  primaryButtonHref,
  secondaryButtonText = 'Hablar por WhatsApp',
  secondaryButtonHref
} = Astro.props;
---

<section class="mx-auto w-full max-w-6xl px-4 py-14 md:px-8 md:py-18" data-reveal>
  <div class="relative overflow-hidden rounded-3xl border border-slate-800/10 bg-slate-900 p-8 text-center text-white shadow-2xl md:p-12">
    <div class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(circle_at_8%_12%,_rgba(52,211,153,0.32),transparent_35%),radial-gradient(circle_at_93%_80%,_rgba(14,165,233,0.26),transparent_34%)]"></div>
    <h2 class="mx-auto max-w-4xl text-balance text-3xl font-black leading-tight md:text-4xl">{title}</h2>
    <p class="mx-auto mt-4 max-w-3xl text-slate-200 md:text-lg">{description}</p>
    <div class="mt-7 flex flex-wrap items-center justify-center gap-3">
      <a href={primaryButtonHref} target="_blank" rel="noopener noreferrer" class="btn-primary" data-cta-audit="section_cta_primary">{primaryButtonText}</a>
      {secondaryButtonHref && (
        <a href={secondaryButtonHref} target="_blank" rel="noopener noreferrer" class="btn-secondary !border-white/35 !bg-white/10 !text-white hover:!bg-white/15" data-cta-whatsapp="section_cta_secondary">{secondaryButtonText}</a>
      )}
    </div>
  </div>
</section>
