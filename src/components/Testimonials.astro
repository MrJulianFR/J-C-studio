---
interface Testimonial {
  quote: string;
  name: string;
  clinic: string;
}

interface Props {
  items: Testimonial[];
}

const { items } = Astro.props;
---

<section class="mx-auto w-full max-w-6xl px-4 py-14 md:px-8 md:py-18">
  <h2 class="text-balance text-3xl font-black text-slate-900 md:text-4xl" data-reveal>Clinicas que hoy consiguen mas citas por WhatsApp</h2>
  <div class="mt-8 grid gap-4 md:grid-cols-3">
    {
      items.map((item, index) => (
        <figure data-reveal class="surface-card rounded-2xl p-5" style={`transition-delay:${index * 80}ms`}>
          <blockquote class="text-sm leading-relaxed text-slate-700">"{item.quote}"</blockquote>
          <figcaption class="mt-4 text-sm font-semibold text-slate-900">{item.name}</figcaption>
          <p class="text-xs text-slate-500">{item.clinic}</p>
        </figure>
      ))
    }
  </div>
</section>
