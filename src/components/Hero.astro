---
interface Props {
  title: string;
  subtitle: string;
  ctaText?: string;
  ctaHref: string;
}

const { title, subtitle, ctaText = 'Ver demo en WhatsApp', ctaHref } = Astro.props;
---

<section class="relative overflow-hidden">
  <div class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(circle_at_top_right,_rgba(16,185,129,0.22),transparent_42%),radial-gradient(circle_at_bottom_left,_rgba(14,165,233,0.16),transparent_35%)]"></div>

  <div class="mx-auto grid w-full max-w-6xl gap-9 px-4 py-14 md:grid-cols-[1.05fr_0.95fr] md:items-center md:gap-10 md:px-8 md:py-22 lg:py-24">
    <div data-reveal="left">
      <p class="mb-4 inline-flex rounded-full border border-emerald-200 bg-emerald-50 px-3 py-1 text-xs font-bold uppercase tracking-[0.14em] text-emerald-700">
        Automatizacion para clinicas en Colombia
      </p>
      <h1 class="text-balance text-4xl font-black leading-[1.05] text-slate-900 md:text-5xl lg:text-[3.35rem]">{title}</h1>
      <p class="mt-5 max-w-2xl text-[1.05rem] leading-relaxed text-slate-600 md:text-lg">{subtitle}</p>
      <div class="mt-8 flex flex-wrap gap-3 md:gap-4">
        <a href={ctaHref} target="_blank" rel="noopener noreferrer" class="btn-primary" data-cta-whatsapp="hero_primary">{ctaText}</a>
        <a href="/como-funciona" class="btn-secondary">Ver como funciona</a>
      </div>
      <p class="mt-4 text-xs font-medium text-slate-500">No es solo un chatbot. Es un sistema comercial para convertir mas conversaciones en pacientes.</p>
    </div>

    <aside data-reveal="right" class="surface-card rounded-3xl p-4 md:p-6">
      <div class="rounded-2xl border border-emerald-100 bg-emerald-50/70 p-3 text-xs font-semibold text-emerald-700">Mockup de conversacion automatizada</div>
      <div class="mt-4 rounded-2xl border border-slate-200 bg-white p-4">
        <div class="space-y-3 text-sm">
          <div class="flex justify-start">
            <p class="max-w-[80%] rounded-2xl rounded-bl-md bg-slate-100 px-3 py-2 text-slate-700">Hola, precio de toxina botulinica?</p>
          </div>
          <div class="flex justify-end">
            <p class="max-w-[82%] rounded-2xl rounded-br-md bg-emerald-500 px-3 py-2 text-white">Hola, te ayudo ahora mismo. Te interesa zona frente o tercio superior completo?</p>
          </div>
          <div class="flex justify-start">
            <p class="max-w-[80%] rounded-2xl rounded-bl-md bg-slate-100 px-3 py-2 text-slate-700">Tercio superior. Quiero cita esta semana.</p>
          </div>
          <div class="flex justify-end">
            <p class="max-w-[82%] rounded-2xl rounded-br-md bg-emerald-500 px-3 py-2 text-white">Perfecto. Tengo cupo manana 4:30 pm o jueves 11:00 am. Cual prefieres?</p>
          </div>
        </div>
      </div>
      <a href={ctaHref} target="_blank" rel="noopener noreferrer" class="btn-primary mt-5 w-full" data-cta-whatsapp="hero_card">Probar ahora en WhatsApp</a>
    </aside>
  </div>
</section>
