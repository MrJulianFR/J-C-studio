---
interface Props {
  title: string;
  subtitle: string;
  primaryCtaText?: string;
  primaryCtaHref: string;
  secondaryCtaText?: string;
  secondaryCtaHref?: string;
}

const {
  title,
  subtitle,
  primaryCtaText = 'Agendar auditoria gratuita',
  primaryCtaHref,
  secondaryCtaText = 'Hablar por WhatsApp',
  secondaryCtaHref
} = Astro.props;

const highlightedTitle = title.replace(/\b(WhatsApp|citas?|cita)\b/gi, '<span class="text-[#25D366]">$1</span>');
---

<section class="relative overflow-hidden">
  <div class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(circle_at_top_right,_rgba(34,211,238,0.24),transparent_42%),radial-gradient(circle_at_bottom_left,_rgba(22,199,132,0.2),transparent_35%)]"></div>

  <div class="mx-auto grid w-full max-w-6xl gap-5 px-4 py-7 sm:gap-6 sm:py-8 md:grid-cols-[1.05fr_0.95fr] md:items-center md:gap-10 md:px-8 md:py-20 lg:py-24">
    <div data-reveal="left" class="hero-panel mx-auto w-full max-w-[34rem] rounded-2xl border border-slate-800/70 bg-[linear-gradient(145deg,#0b1324,#141f33)] p-3 shadow-2xl sm:p-4 md:mx-0 md:max-w-none md:rounded-3xl md:p-8 lg:p-10">
      <p class="text-fade-up mb-2 inline-flex rounded-full border border-emerald-300/30 bg-emerald-400/10 px-2.5 py-1 text-[9px] font-bold uppercase tracking-[0.12em] text-emerald-200 sm:mb-3 sm:px-3 sm:text-[10px] md:mb-4 md:text-xs">
        Automatizacion para clinicas en Colombia
      </p>
      <h1 class="text-fade-up text-balance text-[1.65rem] font-black leading-[1.03] text-slate-50 sm:text-[1.95rem] md:text-5xl lg:text-[3.35rem]" set:html={highlightedTitle}></h1>
      <p class="text-fade-up mt-3 max-w-2xl text-[0.9rem] leading-relaxed text-slate-300 sm:text-[0.96rem] md:mt-5 md:text-lg">{subtitle}</p>
      <div class="mt-4 flex flex-wrap gap-2.5 sm:mt-5 sm:gap-3 md:mt-8 md:gap-4">
        <a href={primaryCtaHref} target="_blank" rel="noopener noreferrer" class="btn-primary" data-cta-audit="hero_primary">{primaryCtaText}</a>
        {secondaryCtaHref && (
          <a href={secondaryCtaHref} target="_blank" rel="noopener noreferrer" class="btn-secondary !border-slate-500 !bg-white/5 !text-slate-100 hover:!bg-white/10" data-cta-whatsapp="hero_secondary">{secondaryCtaText}</a>
        )}
      </div>
      <p class="text-fade-up mt-2 text-[10px] font-medium text-slate-400 sm:mt-3 sm:text-[11px] md:mt-4 md:text-xs">No solo instalamos un bot. Creamos un sistema que responde, hace seguimiento y convierte conversaciones en citas.</p>
    </div>

    <aside data-reveal="right" class="chat-mockup surface-card mx-auto w-full max-w-[24rem] rounded-3xl border border-white/15 bg-[#0F2438] p-3 shadow-2xl md:mx-0 md:max-w-[26rem] md:p-4">
      <div class="rounded-2xl border border-white/15 bg-white/5 px-3 py-2 text-[11px] font-semibold text-white">Cita agendada automaticamente</div>
      <div class="mt-3 overflow-hidden rounded-2xl border border-white/15 bg-[#ffffff] shadow-inner">
        <div class="flex items-center gap-2.5 border-b border-[#e2e8f0] bg-[#f8fafc] px-2.5 py-2">
          <span class="inline-flex h-7 w-7 items-center justify-center rounded-full bg-[#25D366] text-[10px] font-bold text-white">CE</span>
          <div>
            <p class="text-[13px] font-semibold text-[#0f172a]">Clinica Estetica Medellin</p>
            <p class="text-[10px] text-[#64748b]">en linea</p>
          </div>
        </div>

        <div class="space-y-2 p-2.5 text-[13px]">
          <div class="chat-row chat-left chat-appear-1">
            <p class="chat-bubble chat-user">Hola, cuanto cuesta la limpieza facial profunda?</p>
            <span class="chat-time">10:32 AM</span>
          </div>

          <div class="chat-row chat-right chat-appear-2">
            <p class="chat-bubble chat-clinic">Hola. Claro, te ayudo. Es tu primera vez en la clinica?</p>
            <span class="chat-time">10:32 AM ✓✓</span>
          </div>

          <div class="chat-row chat-left chat-appear-3">
            <p class="chat-bubble chat-user">Si, y quiero agendar esta semana.</p>
            <span class="chat-time">10:33 AM</span>
          </div>

          <div class="chat-row chat-right chat-appear-4">
            <p class="chat-bubble chat-clinic">Perfecto. Tenemos disponibilidad mañana a las 4:30 pm o jueves 11:00 am. Cual prefieres?</p>
            <span class="chat-time">10:33 AM ✓✓</span>
          </div>

          <div class="chat-row chat-left chat-appear-5">
            <p class="chat-bubble chat-user">Para mañana esta bien.</p>
            <span class="chat-time">10:34 AM</span>
          </div>

          <div class="chat-row chat-right chat-appear-5">
            <p class="chat-bubble chat-clinic">Listo. Tu cita quedo agendada para manana a las 4:30 pm.</p>
            <span class="chat-time">10:34 AM ✓✓</span>
          </div>

          <div class="chat-typing">
            <span class="typing-dot"></span>
            <span class="typing-dot"></span>
            <span class="typing-dot"></span>
          </div>
        </div>
      </div>
      <p class="mt-2.5 text-center text-[11px] font-semibold text-[#25D366]">Respuesta en 8 segundos</p>
      <a href={primaryCtaHref} target="_blank" rel="noopener noreferrer" class="btn-primary mt-4 w-full" data-cta-audit="hero_card_primary">Agendar auditoria gratuita</a>
      {secondaryCtaHref && (
        <a href={secondaryCtaHref} target="_blank" rel="noopener noreferrer" class="btn-secondary mt-2.5 w-full" data-cta-whatsapp="hero_card_secondary">Hablar por WhatsApp</a>
      )}
    </aside>
  </div>
</section>
