---
interface Props {
  title: string;
  subtitle: string;
  primaryCtaText?: string;
  primaryCtaHref: string;
  secondaryCtaText?: string;
  secondaryCtaHref?: string;
}

const {
  title,
  subtitle,
  primaryCtaText = 'Agendar auditoria gratuita',
  primaryCtaHref,
  secondaryCtaText = 'Hablar por WhatsApp',
  secondaryCtaHref
} = Astro.props;
---

<section class="relative overflow-hidden">
  <div class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(circle_at_top_right,_rgba(34,211,238,0.24),transparent_42%),radial-gradient(circle_at_bottom_left,_rgba(22,199,132,0.2),transparent_35%)]"></div>

  <div class="mx-auto grid w-full max-w-6xl gap-9 px-4 py-14 md:grid-cols-[1.05fr_0.95fr] md:items-center md:gap-10 md:px-8 md:py-22 lg:py-24">
    <div data-reveal="left" class="rounded-3xl border border-slate-800/70 bg-[linear-gradient(145deg,#0b1324,#141f33)] p-6 shadow-2xl md:p-8 lg:p-10">
      <p class="mb-4 inline-flex rounded-full border border-emerald-300/30 bg-emerald-400/10 px-3 py-1 text-xs font-bold uppercase tracking-[0.14em] text-emerald-200">
        Automatizacion para clinicas en Colombia
      </p>
      <h1 class="text-balance text-4xl font-black leading-[1.05] text-slate-50 md:text-5xl lg:text-[3.35rem]">{title}</h1>
      <p class="mt-5 max-w-2xl text-[1.05rem] leading-relaxed text-slate-300 md:text-lg">{subtitle}</p>
      <div class="mt-8 flex flex-wrap gap-3 md:gap-4">
        <a href={primaryCtaHref} target="_blank" rel="noopener noreferrer" class="btn-primary" data-cta-audit="hero_primary">{primaryCtaText}</a>
        {secondaryCtaHref && (
          <a href={secondaryCtaHref} target="_blank" rel="noopener noreferrer" class="btn-secondary !border-slate-500 !bg-white/5 !text-slate-100 hover:!bg-white/10" data-cta-whatsapp="hero_secondary">{secondaryCtaText}</a>
        )}
      </div>
      <p class="mt-4 text-xs font-medium text-slate-400">No solo instalamos un bot. Creamos un sistema que responde, hace seguimiento y convierte conversaciones en citas.</p>
    </div>

    <aside data-reveal="right" class="surface-card rounded-3xl border border-cyan-200/40 bg-white/98 p-4 shadow-2xl md:p-6">
      <div class="rounded-2xl border border-cyan-200 bg-cyan-50 p-3 text-xs font-semibold text-cyan-800">Mockup de conversacion automatizada</div>
      <div class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-inner">
        <div class="space-y-3 text-sm">
          <div class="flex justify-start">
            <p class="max-w-[80%] rounded-2xl rounded-bl-md bg-slate-100 px-3 py-2 text-slate-700">Hola, precio de toxina botulinica?</p>
          </div>
          <div class="flex justify-end">
            <p class="max-w-[82%] rounded-2xl rounded-br-md bg-emerald-500 px-3 py-2 text-white">Hola, te ayudo ahora mismo. Te interesa zona frente o tercio superior completo?</p>
          </div>
          <div class="flex justify-start">
            <p class="max-w-[80%] rounded-2xl rounded-bl-md bg-slate-100 px-3 py-2 text-slate-700">Tercio superior. Quiero cita esta semana.</p>
          </div>
          <div class="flex justify-end">
            <p class="max-w-[82%] rounded-2xl rounded-br-md bg-emerald-500 px-3 py-2 text-white">Perfecto. Tengo cupo manana 4:30 pm o jueves 11:00 am. Cual prefieres?</p>
          </div>
        </div>
      </div>
      <a href={primaryCtaHref} target="_blank" rel="noopener noreferrer" class="btn-primary mt-5 w-full" data-cta-audit="hero_card_primary">Agendar auditoria gratuita</a>
      {secondaryCtaHref && (
        <a href={secondaryCtaHref} target="_blank" rel="noopener noreferrer" class="btn-secondary mt-3 w-full" data-cta-whatsapp="hero_card_secondary">Hablar por WhatsApp</a>
      )}
    </aside>
  </div>
</section>
