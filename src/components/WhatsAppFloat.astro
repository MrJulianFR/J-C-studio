---
import { WHATSAPP_LINK } from '../data/site';
---

<a
  href={WHATSAPP_LINK}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Escribenos por WhatsApp"
  data-cta-whatsapp="floating_button"
  class="btn-primary fixed bottom-4 right-4 z-50 gap-2 px-5 py-3 text-sm md:bottom-5 md:right-5"
>
  <span class="inline-flex h-2.5 w-2.5 rounded-full bg-white"></span>
  WhatsApp
</a>
